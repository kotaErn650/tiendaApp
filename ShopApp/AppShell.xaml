<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ShopApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ShopApp.Views"
    FlyoutBehavior="Flyout"
    FlyoutHeaderBehavior="CollapseOnScroll"
    Title="ShopApp">

    <!-- Flyout header -->
    <Shell.FlyoutHeader>
        <VerticalStackLayout BackgroundColor="#512BD4" Padding="20">
            <Label
                FontAttributes="Bold"
                FontSize="22"
                Text="ShopApp"
                TextColor="White" />
            <Label
                FontSize="13"
                Text="Gestión de tienda"
                TextColor="#DDDDDD" />
        </VerticalStackLayout>
    </Shell.FlyoutHeader>

    <!-- Flyout footer -->
    <Shell.FlyoutFooter>
        <VerticalStackLayout BackgroundColor="#F5F5F5" Padding="16,12">
            <Label
                FontSize="11"
                HorizontalTextAlignment="Center"
                Text="ShopApp v1.0 · .NET 10 MAUI"
                TextColor="Gray" />
        </VerticalStackLayout>
    </Shell.FlyoutFooter>

    <!-- Tab bar with main sections -->
    <TabBar>
        <Tab Title="Resumen" Icon="tab_about.png">
            <ShellContent
                Title="Resumen"
                ContentTemplate="{DataTemplate views:MainPage}"
                Icon="tab_about.png"
                Route="summary" />
        </Tab>

        <Tab Title="Productos" Icon="tab_feeds.png">
            <ShellContent
                Title="Productos"
                ContentTemplate="{DataTemplate views:ProductsPage}"
                Icon="tab_feeds.png"
                Route="products" />
        </Tab>
    </TabBar>

</Shell>
