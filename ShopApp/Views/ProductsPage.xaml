<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ShopApp.Views.ProductsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:handlers="clr-namespace:ShopApp.Handlers"
    xmlns:models="clr-namespace:ShopApp.Models"
    Title="Productos">

    <!-- Search handler attached to Shell -->
    <Shell.SearchHandler>
        <handlers:ProductSearchHandler
            Placeholder="Buscar producto..."
            ShowsResults="True" />
    </Shell.SearchHandler>

    <Grid RowDefinitions="Auto,*">

        <!-- Picker de categoría para filtrar -->
        <Grid
            Grid.Row="0"
            Padding="12,8"
            ColumnDefinitions="Auto,*"
            BackgroundColor="#F5F5F5">
            <Label
                Grid.Column="0"
                VerticalOptions="Center"
                Text="Categoría: "
                FontAttributes="Bold" />
            <Picker
                x:Name="CategoryPicker"
                Grid.Column="1"
                Title="Todas"
                SelectedIndexChanged="OnCategoryFilterChanged" />
        </Grid>

        <!-- Products list -->
        <CollectionView
            x:Name="ProductsCollectionView"
            Grid.Row="1"
            SelectionMode="Single"
            SelectionChanged="OnProductSelected">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Product">
                    <Grid Padding="12,10" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">

                        <!-- Nombre -->
                        <Label
                            Grid.Row="0"
                            Grid.Column="0"
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="{Binding Nombre}" />

                        <!-- Precio con color por converter -->
                        <Label
                            Grid.Row="0"
                            Grid.Column="1"
                            FontAttributes="Bold"
                            FontSize="16"
                            HorizontalTextAlignment="End"
                            Text="{Binding Precio, StringFormat='${0:N2}'}"
                            TextColor="{Binding Precio, Converter={StaticResource PrecioParaColorConverter}}" />

                        <!-- Descripción -->
                        <Label
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            FontSize="13"
                            Text="{Binding Descripcion}"
                            TextColor="Gray" />

                        <!-- Stepper para cantidad -->
                        <Grid
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            ColumnDefinitions="Auto,Auto,Auto"
                            Margin="0,4,0,0">
                            <Label
                                Grid.Column="0"
                                VerticalOptions="Center"
                                Text="Cantidad: "
                                FontSize="13" />
                            <Stepper
                                Grid.Column="1"
                                Minimum="1"
                                Maximum="100"
                                Increment="1"
                                Value="1"
                                ValueChanged="OnStepperValueChanged" />
                            <Label
                                x:Name="QuantityLabel"
                                Grid.Column="2"
                                VerticalOptions="Center"
                                FontSize="13"
                                Text="1" />
                        </Grid>

                        <!-- Separator -->
                        <BoxView
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            HeightRequest="1"
                            Color="#EEEEEE"
                            VerticalOptions="End"
                            Margin="0,8,0,0" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="20" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="No se encontraron productos." HorizontalTextAlignment="Center" TextColor="Gray" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

        </CollectionView>

    </Grid>

</ContentPage>
