<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ShopApp.Views.ClientsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:ShopApp.Models"
    Title="Clientes">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Search bar -->
        <SearchBar
            x:Name="ClientSearchBar"
            Grid.Row="0"
            Placeholder="Buscar cliente..."
            TextChanged="OnClientSearchChanged"
            Margin="8" />

        <!-- Clients list -->
        <CollectionView
            x:Name="ClientsCollectionView"
            Grid.Row="1">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Client">
                    <Grid Padding="14,10" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="12">

                        <!-- Avatar circle -->
                        <Border
                            Grid.Row="0"
                            Grid.Column="0"
                            Grid.RowSpan="2"
                            WidthRequest="48"
                            HeightRequest="48"
                            BackgroundColor="#512BD4"
                            StrokeShape="RoundRectangle 24"
                            VerticalOptions="Center">
                            <Label
                                FontAttributes="Bold"
                                FontSize="20"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                TextColor="White"
                                Text="{Binding Nombre[0]}" />
                        </Border>

                        <Label
                            Grid.Row="0"
                            Grid.Column="1"
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="{Binding Nombre}" />
                        <Label
                            Grid.Row="1"
                            Grid.Column="1"
                            FontSize="13"
                            Text="{Binding Direccion}"
                            TextColor="Gray" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="20" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="No se encontraron clientes." HorizontalTextAlignment="Center" TextColor="Gray" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

        </CollectionView>

        <!-- FlexLayout footer bar -->
        <FlexLayout
            Grid.Row="2"
            Padding="12"
            BackgroundColor="#F5F5F5"
            JustifyContent="SpaceBetween"
            AlignItems="Center">
            <Label
                x:Name="LblClientCount"
                FontSize="13"
                TextColor="Gray"
                Text="Total: 0 clientes" />
            <Button
                Text="+ Nuevo Cliente"
                BackgroundColor="#512BD4"
                TextColor="White"
                CornerRadius="6"
                FontSize="13"
                Clicked="OnNewClientClicked" />
        </FlexLayout>

    </Grid>

</ContentPage>
