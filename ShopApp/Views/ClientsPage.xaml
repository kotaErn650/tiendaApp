<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ShopApp.Views.ClientsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Clientes">

    <Grid RowDefinitions="Auto,*">

        <!-- Header bar -->
        <Grid
            Grid.Row="0"
            Padding="16,12"
            BackgroundColor="#F5F5F5"
            ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="16"
                Text="Lista de Clientes"
                VerticalOptions="Center" />
            <Label
                x:Name="LblCount"
                Grid.Column="1"
                FontSize="13"
                Text="0 clientes"
                TextColor="Gray"
                VerticalOptions="Center" />
        </Grid>

        <!-- Clients list -->
        <CollectionView
            x:Name="ClientsCollectionView"
            Grid.Row="1">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid
                        Padding="16,12"
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="12"
                        RowDefinitions="Auto,Auto">

                        <!-- Avatar circle -->
                        <Border
                            Grid.Row="0"
                            Grid.Column="0"
                            Grid.RowSpan="2"
                            BackgroundColor="#512BD4"
                            HeightRequest="44"
                            WidthRequest="44"
                            StrokeShape="RoundRectangle 22"
                            VerticalOptions="Center">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                HorizontalOptions="Center"
                                Text="{Binding Inicial}"
                                TextColor="White"
                                VerticalOptions="Center" />
                        </Border>

                        <!-- Name -->
                        <Label
                            Grid.Row="0"
                            Grid.Column="1"
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="{Binding Nombre}" />

                        <!-- Address -->
                        <Label
                            Grid.Row="1"
                            Grid.Column="1"
                            FontSize="13"
                            Text="{Binding Direccion}"
                            TextColor="Gray" />

                        <!-- Separator -->
                        <BoxView
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            HeightRequest="1"
                            Color="#EEEEEE"
                            Margin="0,8,0,0"
                            VerticalOptions="End" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout
                    HorizontalOptions="Center"
                    Padding="20"
                    VerticalOptions="Center">
                    <Label
                        HorizontalTextAlignment="Center"
                        Text="No hay clientes registrados."
                        TextColor="Gray" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

        </CollectionView>

    </Grid>

</ContentPage>
