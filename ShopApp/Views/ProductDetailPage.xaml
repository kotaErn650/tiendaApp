<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ShopApp.Views.ProductDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Detalle del Producto">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <!-- Header with name and price -->
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                <Label
                    x:Name="LblNombre"
                    Grid.Row="0"
                    Grid.Column="0"
                    FontAttributes="Bold"
                    FontSize="22"
                    Text="{Binding Nombre}" />
                <Label
                    x:Name="LblPrecio"
                    Grid.Row="0"
                    Grid.Column="1"
                    FontAttributes="Bold"
                    FontSize="22"
                    HorizontalTextAlignment="End"
                    Text="{Binding Precio, StringFormat='${0:N2}'}"
                    TextColor="{Binding Precio, Converter={StaticResource PrecioParaColorConverter}}" />
                <Label
                    x:Name="LblCategoria"
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    FontSize="14"
                    Text="{Binding Category.Nombre, StringFormat='Categoría: {0}'}"
                    TextColor="#512BD4" />
            </Grid>

            <BoxView HeightRequest="1" Color="#EEEEEE" />

            <!-- Description -->
            <Label FontAttributes="Bold" FontSize="16" Text="Descripción" />
            <Label
                x:Name="LblDescripcion"
                FontSize="15"
                Text="{Binding Descripcion}"
                TextColor="Gray" />

            <BoxView HeightRequest="1" Color="#EEEEEE" />

            <!-- Editable fields (TwoWay binding) -->
            <Label FontAttributes="Bold" FontSize="16" Text="Editar Producto" />

            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="10">
                <Label Grid.Row="0" Grid.Column="0" VerticalOptions="Center" Text="Nombre:" />
                <Entry
                    Grid.Row="0"
                    Grid.Column="1"
                    Text="{Binding Nombre, Mode=TwoWay}"
                    Placeholder="Nombre del producto" />

                <Label Grid.Row="1" Grid.Column="0" VerticalOptions="Center" Text="Descripción:" />
                <Entry
                    Grid.Row="1"
                    Grid.Column="1"
                    Text="{Binding Descripcion, Mode=TwoWay}"
                    Placeholder="Descripción" />

                <Label Grid.Row="2" Grid.Column="0" VerticalOptions="Center" Text="Precio:" />
                <Entry
                    Grid.Row="2"
                    Grid.Column="1"
                    Keyboard="Numeric"
                    Text="{Binding Precio, Mode=TwoWay, StringFormat='{0:N2}'}"
                    Placeholder="Precio" />
            </Grid>

            <!-- Quantity stepper -->
            <Label FontAttributes="Bold" FontSize="16" Text="Cantidad a pedir" />
            <FlexLayout AlignItems="Center" JustifyContent="Start">
                <Stepper
                    x:Name="QuantityStepper"
                    Minimum="1"
                    Maximum="999"
                    Increment="1"
                    Value="1"
                    ValueChanged="OnQuantityStepperChanged" />
                <Label
                    x:Name="LblQuantity"
                    Margin="10,0,0,0"
                    FontSize="18"
                    FontAttributes="Bold"
                    Text="1" />
            </FlexLayout>

            <!-- Save button -->
            <Button
                Text="Guardar Cambios"
                BackgroundColor="#512BD4"
                TextColor="White"
                CornerRadius="8"
                Clicked="OnSaveClicked" />

            <!-- Back button -->
            <Button
                Text="Volver a Productos"
                BackgroundColor="Gray"
                TextColor="White"
                CornerRadius="8"
                Clicked="OnBackClicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
