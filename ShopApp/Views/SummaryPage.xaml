<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ShopApp.Views.SummaryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Resumen">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label
                FontAttributes="Bold"
                FontSize="26"
                HorizontalOptions="Center"
                Text="Bienvenido a ShopApp" />

            <BoxView
                HeightRequest="2"
                Color="#512BD4"
                HorizontalOptions="Fill" />

            <!-- Summary cards using Grid -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">

                <!-- Products card -->
                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    Padding="16"
                    BackgroundColor="#F0EEFF"
                    StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout Spacing="6">
                        <Label FontAttributes="Bold" FontSize="14" Text="Productos" TextColor="#512BD4" />
                        <Label
                            x:Name="LblTotalProducts"
                            FontSize="32"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center"
                            Text="0" />
                        <Label FontSize="11" Text="registrados" TextColor="Gray" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Clients card -->
                <Border
                    Grid.Row="0"
                    Grid.Column="1"
                    Padding="16"
                    BackgroundColor="#F0FFF0"
                    StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout Spacing="6">
                        <Label FontAttributes="Bold" FontSize="14" Text="Clientes" TextColor="Green" />
                        <Label
                            x:Name="LblTotalClients"
                            FontSize="32"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center"
                            Text="0" />
                        <Label FontSize="11" Text="registrados" TextColor="Gray" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Categories card -->
                <Border
                    Grid.Row="1"
                    Grid.Column="0"
                    Padding="16"
                    BackgroundColor="#FFF8E7"
                    StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout Spacing="6">
                        <Label FontAttributes="Bold" FontSize="14" Text="Categorías" TextColor="Orange" />
                        <Label
                            x:Name="LblTotalCategories"
                            FontSize="32"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center"
                            Text="0" />
                        <Label FontSize="11" Text="disponibles" TextColor="Gray" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Avg price card -->
                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    Padding="16"
                    BackgroundColor="#FFF0F0"
                    StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout Spacing="6">
                        <Label FontAttributes="Bold" FontSize="14" Text="Precio Promedio" TextColor="Red" />
                        <Label
                            x:Name="LblAvgPrice"
                            FontSize="22"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center"
                            Text="$0.00" />
                        <Label FontSize="11" Text="por producto" TextColor="Gray" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- FlexLayout for action buttons -->
            <Label FontAttributes="Bold" FontSize="16" Text="Acciones rápidas" Margin="0,8,0,0" />
            <FlexLayout JustifyContent="SpaceEvenly" Wrap="Wrap">
                <Button
                    Text="Ver Productos"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    CornerRadius="8"
                    Margin="4"
                    Clicked="OnVerProductosClicked" />
                <Button
                    Text="Ver Clientes"
                    BackgroundColor="Green"
                    TextColor="White"
                    CornerRadius="8"
                    Margin="4"
                    Clicked="OnVerClientesClicked" />
            </FlexLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
