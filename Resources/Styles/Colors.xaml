<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Colores principales -->
    <Color x:Key="Primary">#1A73E8</Color>
    <Color x:Key="PrimaryDark">#1557B0</Color>
    <Color x:Key="PrimaryLight">#4D90FE</Color>
    <Color x:Key="Secondary">#E8711A</Color>
    <Color x:Key="SecondaryDark">#B55712</Color>
    <Color x:Key="Tertiary">#1AE87E</Color>

    <!-- Colores de fondo -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="CardBackground">#F5F7FA</Color>
    <Color x:Key="PageBackground">#FFFFFF</Color>

    <!-- Colores de texto -->
    <Color x:Key="TextPrimary">#212121</Color>
    <Color x:Key="TextSecondary">#757575</Color>
    <Color x:Key="TextPlaceholder">#BDBDBD</Color>

    <!-- Colores de estado -->
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Warning">#FFC107</Color>
    <Color x:Key="Error">#F44336</Color>

    <!-- Grises -->
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

</ResourceDictionary>
