<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ShopApp.Views.ClientsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Clientes">

    <CollectionView
        x:Name="ClientsCollection"
        SelectionMode="None">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Grid ColumnDefinitions="Auto,*" Padding="16,12" ColumnSpacing="12">
                    <Frame
                        Grid.Column="0"
                        CornerRadius="24"
                        HeightRequest="48"
                        WidthRequest="48"
                        Padding="0"
                        BackgroundColor="{StaticResource Primary}">
                        <Label
                            FontAttributes="Bold"
                            FontSize="20"
                            HorizontalOptions="Center"
                            Text="👤"
                            TextColor="White"
                            VerticalOptions="Center" />
                    </Frame>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label FontAttributes="Bold" FontSize="16" Text="{Binding Nombre}" />
                        <Label FontSize="13" Text="{Binding Direccion}" TextColor="Gray" />
                    </VerticalStackLayout>
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
